# Database
DATABASE_URL=postgresql+asyncpg://buzz:CHANGE_ME@localhost:5432/buzz_news
DATABASE_URL_RO=postgresql://buzz_ro:CHANGE_ME_RO@localhost:5432/buzz_news

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM writer fallback (primary writer is DeepSeek when configured)
GEMINI_API_KEY=
GEMINI_MODEL_TEXT=gemini-2.5-flash
GEMINI_MODEL_EMBED=gemini-embedding-001
EMBED_DIM=768
GEMINI_FALLBACK_DAILY_CAP=5

# LLM routing / free revision providers
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
MAX_NEW_ARTICLES_PER_DAY=96
DEEPSEEK_DAILY_ARTICLE_CAP=60
LLM_HIGH_TIER_PROVIDER=deepseek:deepseek-v4-flash
LLM_LOW_TIER_PROVIDERS=cerebras:gpt-oss-120b,groq:meta-llama/llama-4-scout-17b-16e-instruct,groq:qwen/qwen3-32b
LLM_REVISION_PROVIDERS=cerebras:gpt-oss-120b,groq:meta-llama/llama-4-scout-17b-16e-instruct,groq:qwen/qwen3-32b,deepseek:deepseek-v4-flash
FREE_LLM_DAILY_TOKEN_SOFT_CAP=900000
GROQ_DAILY_TOKEN_SOFT_CAP=450000

# Embeddings
EMBED_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIM=768
MAX_DAILY_EMBED_TOKENS=1500000

# LLM (fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Image providers
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# Reddit
REDDIT_USER_AGENT=buzz-news/0.1 (by /u/TODO_PRE_LAUNCH contact:TODO_PRE_LAUNCH@example.com)

# Tavily (free tier: 1000 searches/month)
TAVILY_API_KEY=TODO_BEFORE_PHASE_1

# OpenClaw bridge
OPENCLAW_GATEWAY_URL=http://127.0.0.1:19262
OPENCLAW_BROWSER_FALLBACK_ENABLED=false

# Buzz alert webhook
BUZZ_WEBHOOK_URL=

# Cloudflare
CLOUDFLARE_ZONE_ID=TODO_PRE_LAUNCH
CLOUDFLARE_API_TOKEN=TODO_PRE_LAUNCH
CLOUDFLARE_PURGE_ENABLED=false

# Site
SITE_BASE_URL=https://TODO_PRE_LAUNCH
SITE_HOST=TODO_PRE_LAUNCH
STATIC_DIR=/var/lib/buzz-news/static
LOG_DIR=/var/log/buzz-news
TZ=Asia/Kolkata

# Scoring constants
SCORE_TIME_GRAVITY=1.5
SCORE_DIVERSITY_CAP=8
BUZZ_VELOCITY_THRESHOLD=0.4
BUZZ_MIN_AUTHORITATIVE=3

# Pipeline cadence
FETCH_INTERVAL_MIN=15
EMBED_INTERVAL_MIN=10
CLUSTER_INTERVAL_MIN=10
SCORE_INTERVAL_MIN=10
SANITY_SWEEP_INTERVAL_MIN=60
PUBLISH_INTERVAL_MIN=15
TOP_N_PER_CYCLE=1
RAW_EMBED_BATCH_LIMIT=200
CLUSTER_BATCH_LIMIT=250

# Retention (days)
RETENTION_RAW_ITEMS_DAYS=90
RETENTION_CLUSTER_SCORES_DAYS=30
RETENTION_BUZZ_EVENTS_DAYS=365
RETENTION_IMAGES_DAYS=365

# Nightly DB backup (rsync over SSH to a remote VPS). systemd timer reads these.
BACKUP_SSH_HOST=
BACKUP_SSH_USER=
BACKUP_SSH_PORT=22
BACKUP_REMOTE_DIR=/home/buzz-backups
BACKUP_SSH_KEY=/home/ubuntu/.ssh/buzz_backup_ed25519
